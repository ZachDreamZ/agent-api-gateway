{
  "name": "agent-api-gateway",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/api/index.ts",
    "dev:dashboard": "vite dev src/dashboard --port 5173",
    "dev:mcp": "tsx watch src/mcp/index.ts",
    "typecheck": "tsc --noEmit --checkers 4",
    "test": "tsx --test tests/**/*.test.ts",
    "test:product": "tsx --test tests/product-core.test.ts",
    "check:secrets": "node scripts/check-secrets.mjs",
    "access:review": "tsx scripts/access-review.ts",
    "build:dashboard": "vite build src/dashboard",
    "build": "tsc && vite build src/dashboard",
    "start": "node dist/api/index.js",
    "mcp": "tsx src/mcp/index.ts",
    "mcp:setup": "tsx src/mcp/setup.ts",
    "mcp:prod": "node dist/mcp/index.js",
    "verify:mcp": "node --import tsx scripts/verify-mcp.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@better-auth/api-key": "^1.6.23",
    "@better-auth/core": "^1.6.23",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@polar-sh/sdk": "^0.48.1",
    "better-auth": "^1.6.23",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "hono": "^4.6.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "pg": "^8.22.0",
    "playwright": "^1.49.0",
    "react-router-dom": "^7.18.1",
    "web-vitals": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2",
    "vite": "^6.0.0"
  },
  "overrides": {
    "zod": "^4.4.3"
  }
}
