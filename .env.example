# ─── Server ───
PORT=3000
# No wildcard in production. List the exact origins that may call the API
# (comma-separated). The dashboard is served same-origin, so it needs no entry.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info

# ─── LLM Extraction ───
# Default: Gemini Flash 2.0 (free tier, 1500 req/day).
# Set EXTRACTION_LLM=claude to use Claude Sonnet 4 instead.
EXTRACTION_LLM=gemini
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=   # Only needed if EXTRACTION_LLM=claude

# ─── Supabase (Better Auth uses this directly for its Postgres schema) ───
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (used by Better Auth's DB adapter).
# Format: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_URL=

# ─── Better Auth ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=
# Public base URL of this service (used for callback/reset links + CORS).
BETTER_AUTH_URL=http://localhost:3000

# ─── GitHub OAuth (optional; enables "Continue with GitHub") ───
# Create an OAuth App: https://github.com/settings/developers
# Homepage: APP_DOMAIN
# Authorization callback URL (must match BETTER_AUTH_URL):
#   https://agentapigw.dpdns.org/api/auth/callback/github
#   http://localhost:3000/api/auth/callback/github  (local)
# Also add https://agent-api-gateway.onrender.com/api/auth/callback/github if using onrender host.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google OAuth (optional; enables "Continue with Google") ───
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web application)
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:
#   https://agentapigw.dpdns.org
#   http://localhost:3000
# Authorized redirect URIs:
#   https://agentapigw.dpdns.org/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
#   https://agent-api-gateway.onrender.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cache ───
# Leave empty for in-memory cache (free). Set for Redis/Upstash.
REDIS_URL=

# ─── Polar billing (required for checkout + portal; endpoints return 503 without it) ───
# Create products in the Polar dashboard (Products → New → Recurring) for each paid tier,
# then set their IDs below. Get POLAR_ACCESS_TOKEN and POLAR_WEBHOOK_SECRET from Polar
# (Settings → Access Tokens / Webhooks). Point the webhook endpoint at /webhooks/polar.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=production
POLAR_PRODUCT_HOBBY=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_SCALE=
# Optional one-time credit packs (create as one-time products in Polar)
# POLAR_PRODUCT_STARTER is reused for the $1 / 1,000-credit pack.
POLAR_PRODUCT_CREDITS_5K=
POLAR_PRODUCT_CREDITS_25K=
APP_DOMAIN=http://localhost:3000

# ─── API Key Config ───
API_KEY_PREFIX=sk-

# ─── MCP server (local agent tools; never commit real keys) ───
# AGENT_API_KEY=sk-your-dashboard-key
# API_BASE_URL=https://agentapigw.dpdns.org/v1

# Public support email shown on Polar / product pages
SUPPORT_EMAIL=support@agentapigw.dpdns.org

# ─── Transactional email (verification + password reset) ───
# Resend free tier: https://resend.com
# Without RESEND_API_KEY, links are logged to the console in non-production only.
# Production requires RESEND_API_KEY or email/password signup verification will fail to send.
RESEND_API_KEY=
# From address (must be a verified domain in Resend, or use onboarding@resend.dev for tests)
EMAIL_FROM=Agent API <onboarding@resend.dev>
