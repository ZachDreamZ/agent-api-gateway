# ─── Server ───
PORT=3000
# No wildcard in production. List the exact origins that may call the API
# (comma-separated). The dashboard is served same-origin, so it needs no entry.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info

# ─── LLM Extraction ───
# Default: Gemini Flash 2.0 (free tier, 1500 req/day).
# Set EXTRACTION_LLM=claude to use Claude Sonnet 4 instead.
EXTRACTION_LLM=gemini
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=   # Only needed if EXTRACTION_LLM=claude

# ─── Supabase (Better Auth uses this directly for its Postgres schema) ───
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (used by Better Auth's DB adapter).
# Format: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_URL=

# ─── Better Auth ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=
# Public base URL of this service (used for callback/reset links + CORS).
BETTER_AUTH_URL=http://localhost:3000

# ─── Cache ───
# Leave empty for in-memory cache (free). Set for Redis/Upstash.
REDIS_URL=

# ─── Polar billing (required for checkout + portal; endpoints return 503 without it) ───
# Create products in the Polar dashboard (Products → New → Recurring) for each paid tier,
# then set their IDs below. Get POLAR_ACCESS_TOKEN and POLAR_WEBHOOK_SECRET from Polar
# (Settings → Access Tokens / Webhooks). Point the webhook endpoint at /webhooks/polar.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=production
POLAR_PRODUCT_HOBBY=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_SCALE=
APP_DOMAIN=http://localhost:3000

# ─── API Key Config ───
API_KEY_PREFIX=sk-
